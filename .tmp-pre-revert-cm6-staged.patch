new file mode 100644
index 0000000..9495c26
--- /dev/null
+++ b/src/logic/undo-redo/unified-commands.ts
@@ -0,0 +1,67 @@
+import { Platform } from 'obsidian';
+import type InkPlugin from 'src/main';
+
+const COMMAND_UNIFIED_UNDO_ID = 'unified-undo';
+const COMMAND_UNIFIED_REDO_ID = 'unified-redo';
+
+function getUndoRedoDispatchTarget(): EventTarget {
+	const activeElement = document.activeElement;
+	if (activeElement instanceof HTMLElement) {
+		const cmEditorHost = activeElement.closest('.cm-editor');
+		if (cmEditorHost) return cmEditorHost;
+		if (activeElement.classList.contains('cm-editor')) return activeElement;
+	}
+
+	const firstCmEditor = document.querySelector('.cm-editor');
+	if (firstCmEditor) return firstCmEditor;
+
+	return document;
+}
+
+function createSyntheticUndoRedoKeyboardEvent(shiftKey: boolean): KeyboardEvent {
+	const isMacLikePlatform = Platform.isMacOS || Platform.isIosApp;
+
+	return new KeyboardEvent('keydown', {
+		key: 'z',
+		code: 'KeyZ',
+		metaKey: isMacLikePlatform,
+		ctrlKey: !isMacLikePlatform,
+		shiftKey,
+		bubbles: true,
+		cancelable: true,
+	});
+}
+
+function dispatchSyntheticUndoRedoKeydown(shiftKey: boolean): void {
+	const primaryTarget = getUndoRedoDispatchTarget();
+	primaryTarget.dispatchEvent(createSyntheticUndoRedoKeyboardEvent(shiftKey));
+
+	// Some hosts don't route synthetic keyboard events through the same path as user keypresses.
+	// Mirror to document as a fallback so the DOM capture handler still sees the event.
+	if (primaryTarget !== document) {
+		document.dispatchEvent(createSyntheticUndoRedoKeyboardEvent(shiftKey));
+	}
+}
+
+export function dispatchSyntheticUndoKeydown(_plugin: InkPlugin): void {
+	dispatchSyntheticUndoRedoKeydown(false);
+}
+
+export function dispatchSyntheticRedoKeydown(_plugin: InkPlugin): void {
+	dispatchSyntheticUndoRedoKeydown(true);
+}
+
+export function registerUnifiedUndoRedoCommands(plugin: InkPlugin): void {
+	plugin.addCommand({
+		id: COMMAND_UNIFIED_UNDO_ID,
+		name: 'Unified undo',
+		callback: () => dispatchSyntheticUndoKeydown(plugin),
+	});
+
+	plugin.addCommand({
+		id: COMMAND_UNIFIED_REDO_ID,
+		name: 'Unified redo',
+		callback: () => dispatchSyntheticRedoKeydown(plugin),
+	});
+}
+
